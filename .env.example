# ============================================================================
# HelloClaw 环境变量配置
# ============================================================================

# LLM 配置
LLM_MODEL_ID=glm-5
# 从系统环境变量读取，不建议在 .env 中保存明文 key
# 优先读取 MINIMAX_API_KEY，其次兼容 LLM_API_KEY
MINIMAX_API_KEY=
LLM_API_KEY=
LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4/

# 可选：Brave Search API Key
# 不配置时，search_web 会自动退化到公开搜索结果页抓取模式
# BRAVE_API_KEY=your-brave-api-key-here

# 服务配置
PORT=8000
CORS_ORIGINS=http://localhost:5173

# 工作空间配置
WORKSPACE_PATH=~/.helloclaw/workspace
